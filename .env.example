# Wallet that receives x402 payments
PAY_TO_ADDRESS=0xYourEvmAddressHere

# x402 network (CAIP-2). Testnet: eip155:84532  |  Base mainnet: eip155:8453
NETWORK=eip155:84532

# Facilitator URL.
# Testnet: https://x402.org/facilitator
# Mainnet: use a production facilitator (do NOT use x402.org for mainnet)
FACILITATOR_URL=https://x402.org/facilitator

# Set to production|prod|mainnet to REQUIRE NETWORK + FACILITATOR_URL (no silent testnet defaults)
# ENVIRONMENT=development

# Yellow Card (official Get Rates — HMAC auth)
# Docs: https://docs.yellowcard.engineering/reference/get-rates
YELLOWCARD_API_KEY=
YELLOWCARD_API_SECRET=
# production: https://api.yellowcard.io  |  sandbox: https://sandbox.api.yellowcard.io
YELLOWCARD_BASE_URL=https://api.yellowcard.io
# Weight used when the provider does not return a liquidity figure
YELLOWCARD_DEFAULT_LIQUIDITY=1000000

# Poll interval minutes (default 3)
POLL_INTERVAL_MINUTES=3
